# Copy to .env and fill in. Never commit the real .env.
# Generate a token on the VPS with:  openssl rand -hex 16
ACCESS_TOKEN=

# Cache size limit in MB (LRU eviction).
MAX_CACHE_MB=4096

# Optional — only if YouTube starts blocking the server IP.
# Paste the full contents of a Netscape cookies.txt here (one line, \n escaped),
# or mount a file and use COOKIES_FILE instead.
# COOKIES_CONTENT=
